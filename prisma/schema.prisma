model Limit {
  id    Int     @id @default(autoincrement())
  department_id Int
  Department Department @relation(fields: [department_id], references: [id])
  limit_dose_mSv Decimal @db.Decimal(10, 3)
  role_id Int
  Role Role @relation(fields: [role_id], references: [id])
  placement Placement
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PermissionName {
  ALL
  DEPARTMENT
  WORKER
}

model Permission {
  id    Int     @id @default(autoincrement())
  name PermissionName @unique

  Role Role[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//predefined constants for radiation_type in Reading
enum Radiation_Type {
  ALPHA
  BETA
  GAMMA
  NEUTRON
  XRAY
}

model Reading {
  id    Int     @id @default(autoincrement())
  dosimeter_id Int
  Dosimeter Dosimeter @relation(fields: [dosimeter_id], references: [id])
  is_minimal Boolean
  is_null Boolean
  reading_date DateTime
  reading_period_start DateTime
  reading_period_end DateTime
  dose_mSv_chest Decimal @db.Decimal(10, 3)
  dose_mSv_eye Decimal @db.Decimal(10, 3)
  dose_mSv_extremities Decimal @db.Decimal(10, 3)
  dose_mSv_foetal Decimal @db.Decimal(10, 3)
  total_mSv_chest Decimal @db.Decimal(10, 3)
  total_mSv_eye Decimal @db.Decimal(10, 3)
  total_mSv_extremities Decimal @db.Decimal(10, 3)
  total_mSv_foetal Decimal @db.Decimal(10, 3)
  radiation_type Radiation_Type

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dosimeter_id, reading_date])
}


model Role {
  id    Int     @id @default(autoincrement())
  name String @unique
  Department Department[]
  Worker Worker[]
  Limit Limit[]
  Permission Permission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id    Int     @id @default(autoincrement())
  email String  @unique
  username String @unique
  name  String?
  password_hash String
  Worker Worker?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Worker {
  id    Int @id @default(autoincrement())
  Department Department[] //worker can work in several departments
  Dosimeter Dosimeter[] //worker can wear several dosimeters
  first_name String
  last_name String
  Role Role[] //worker can perform several roles

  //A worker has a unique user account
  //User accounts who have a Worker record can't be deleted
  user_id Int @unique
  User User @relation(fields: [user_id], references: [id], onDelete: Restrict) 

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([first_name, last_name])
}

